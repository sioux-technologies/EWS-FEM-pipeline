# Python cache and local tooling
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local logs and temporary files
*.log
*.tmp

# COMSOL/FEM heavy generated artefacts
*.mph
*.mph.*
*.recovery
*.status
*.class
*.comsol_command.txt
**/comsol_configuration/
**/org.eclipse.core.runtime/
**/org.eclipse.osgi/
**/org.eclipse.update/

# Generated run/build/solve folders
# Keep lightweight run provenance, but never track generated FEM artefacts.
runs/**
!runs/**/
!runs/**/*.toml
!runs/**/README.md
runs/**/output/
runs/**/outputs/
runs/**/output_*/
runs/**/build/
runs/**/solve/
runs/**/prepare/
runs/comsol_full_overnight_suite/
output/

# FEBio/mesh/generated numerical artefacts
*.vtk
*.vtu
*.xplt
*.feb
*.npy
*.npz
*.obj
*.mtl
*.stl

# Keep active lightweight analysis, ignore older duplicate analysis outputs
analysis_output/figures/
analysis_output/metrics_compare/
analysis_output/legacy_benchmark/

# Large manual COMSOL raw surface exports; keep derived summaries/plots instead.
analysis_output/**/outer_skin_free_bnd_dataset*.csv
analysis_output/**/surface_timeseries*.csv
analysis_output/**/*_surface.csv
!analysis_output/**/surface_comparison/**/*.csv
!analysis_output/**/comparison_figures/*.csv
!analysis_output/**/manual_postprocess_summary.csv
!analysis_output/**/stage5_manual_postprocess_summary.csv

# Local archive/delete staging areas are intentionally not versioned.
**/delete_candidates/
**/_archive_delete_candidates/

# OS/editor noise
.DS_Store
Thumbs.db
